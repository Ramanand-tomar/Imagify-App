{
  "expo": {
    "name": "Imagify AI",
    "slug": "imagify-ai",
    "version": "0.1.0",
    "icon": "./assets/icon.png",
    "orientation": "portrait",
    "scheme": "imagify",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": false,
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.imagify.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSPhotoLibraryUsageDescription": "Imagify needs access to your photos so you can upload images for processing.",
        "NSCameraUsageDescription": "Imagify needs camera access so you can scan documents.",
        "NSPhotoLibraryAddUsageDescription": "Imagify saves processed files to your photo library when you tap Save."
      }
    },
    "android": {
      "package": "com.imagify.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#6366F1"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.INTERNET"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "Imagify needs access to your photos so you can upload images for processing.",
          "cameraPermission": "Imagify needs camera access so you can scan documents."
        }
      ],
      "expo-asset",
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "0e45188e-fb2b-4bd8-b522-99ab0e2ccb57"
      }
    }
  }
}
