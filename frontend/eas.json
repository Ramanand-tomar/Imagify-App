{
  "cli": {
    "version": ">= 18.6.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://imagify-api-znfn.onrender.com",
        "EXPO_PUBLIC_WS_URL": "wss://imagify-api-znfn.onrender.com/ws"
      }
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_API_URL": "https://imagify-api-znfn.onrender.com",
        "EXPO_PUBLIC_WS_URL": "wss://imagify-api-znfn.onrender.com/ws"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
