# --- Database (Production: Neon.tech / Render Postgres) ---
DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/dbname?ssl=require
SYNC_DATABASE_URL=postgresql+psycopg2://user:pass@host:5432/dbname?ssl=require

# --- Cache & Task Queue (Production: Upstash / Redislabs) ---
REDIS_URL=redis://:password@host:port/0

# --- Security ---
# Generate with: openssl rand -hex 32
JWT_SECRET=your-super-secret-key-change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- ImageKit.io (Storage) ---
IMAGEKIT_PUBLIC_KEY=public_xxxxxxxxxxxx
IMAGEKIT_PRIVATE_KEY=private_xxxxxxxxxxxx
IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/your_id

# --- CORS ---
CORS_ORIGINS=https://your-app.vercel.app,http://localhost:19006

# --- Rate Limiting ---
RATE_LIMIT_DEFAULT=100/minute
