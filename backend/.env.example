# Copy to backend/.env and fill in real values. NEVER commit backend/.env.
#
# To run locally with relaxed validation (placeholders allowed, wildcard CORS,
# etc.), set ENVIRONMENT=development. Production deployments MUST leave this
# unset (defaults to "production") so config.py's startup validation catches
# any leftover placeholder values.

ENVIRONMENT=development

# --- Database (Production: Neon.tech / Render Postgres) ---
DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/dbname?ssl=require
SYNC_DATABASE_URL=postgresql+psycopg2://user:pass@host:5432/dbname?ssl=require

# --- Cache & Task Queue (Production: Upstash / Redislabs) ---
REDIS_URL=redis://:password@host:port/0

# --- Security ---
# Generate with: openssl rand -hex 32  (must be >= 32 chars)
JWT_SECRET=your-super-secret-key-change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- ImageKit.io (Storage) ---
IMAGEKIT_PUBLIC_KEY=public_xxxxxxxxxxxx
IMAGEKIT_PRIVATE_KEY=private_xxxxxxxxxxxx
IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/your_id

# --- CORS ---
# Comma-separated explicit allowlist. NEVER use '*' alongside credentials in
# production — config.py will refuse to start.
CORS_ORIGINS=https://your-app.example.com,http://localhost:19006
CORS_ALLOW_CREDENTIALS=true

# --- Rate Limiting ---
RATE_LIMIT_DEFAULT=100/minute
